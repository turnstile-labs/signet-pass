# ── Product URLs ──────────────────────────────────────────────────────────────
# Production URLs for products built on Signet.
# Leave unset in local dev — each app's localhost port is used as fallback.
NEXT_PUBLIC_PASS_URL=https://pass.signet.xyz
NEXT_PUBLIC_AIRDROP_URL=https://airdrop.signet.xyz
NEXT_PUBLIC_RUG_REGISTRY_URL=https://rug.signet.xyz

# ── RPC / Infra ───────────────────────────────────────────────────────────────
# Alchemy API key — used for Base Sepolia RPC transport (optional; falls back to public RPC).
# Get your key at: https://dashboard.alchemy.com/apps
NEXT_PUBLIC_ALCHEMY_API_KEY=

# WalletConnect project ID — required for WalletConnect connector in ConnectKit.
# Get your ID at: https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# ── DKIM registry tooling (optional) ──────────────────────────────────────────
# GitHub personal access token — used to query open DKIM key registration issues.
# Required only if you want the "open issues" count to show in DomainsStatus.
NEXT_PUBLIC_GITHUB_DKIM_PAT=

# GitHub repo for DKIM key registration issues (e.g. "org/repo").
NEXT_PUBLIC_GITHUB_REPOSITORY=turnstile-labs/signet
