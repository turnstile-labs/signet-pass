# ── Signet Protocol ───────────────────────────────────────────────────────────
# URL of the Signet Protocol app (hosts /prove and /artifacts).
# Production: https://signet.xyz  |  Local dev: http://localhost:3000
NEXT_PUBLIC_SIGNET_URL=http://localhost:3000

# Base URL for ZK proving artifacts (signet_email.wasm + signet_email.zkey).
# These are served from apps/protocol at /artifacts.
# Production: https://signet.xyz/artifacts  |  Local dev: http://localhost:3000/artifacts
NEXT_PUBLIC_ARTIFACT_BASE_URL=http://localhost:3000/artifacts

# ── This app ──────────────────────────────────────────────────────────────────
# Canonical URL of this app — used to build the shareable /verify links.
# Production: https://pass.signet.xyz  |  Local dev: http://localhost:3003
NEXT_PUBLIC_PASS_URL=http://localhost:3003

# ── Contracts ─────────────────────────────────────────────────────────────────
# Address of the deployed Signet pass factory on Base Sepolia.
# Deploy via `forge script script/DeployPass.s.sol` (see contracts/script/DeployPass.s.sol),
# or use the shared Signet-maintained factory: 0x19F2d083BF21Bb7eB95893aDc28D0D9Cb61F22Bf
NEXT_PUBLIC_FACTORY_ADDRESS=0x19F2d083BF21Bb7eB95893aDc28D0D9Cb61F22Bf

# ── RPC / Infra ───────────────────────────────────────────────────────────────
# Alchemy API key — used for Base Sepolia RPC transport (optional; falls back to public RPC).
# Get your key at: https://dashboard.alchemy.com/apps
NEXT_PUBLIC_ALCHEMY_API_KEY=

# WalletConnect project ID — required for WalletConnect connector in ConnectKit.
# Get your ID at: https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# ── Development only ──────────────────────────────────────────────────────────
# Set to "true" to skip ZK proof generation (uses a dummy attestation instead).
# NEVER enable this in production — it completely bypasses the sybil-resistance guarantee.
NEXT_PUBLIC_DEV_BYPASS=false
