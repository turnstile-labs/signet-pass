# ── This app ──────────────────────────────────────────────────────────────────
# Canonical URL of this app — used to build shareable /verify links.
# Production: https://pass.signet.xyz  |  Local dev: unset (uses window.location.origin)
NEXT_PUBLIC_PASS_URL=https://pass.signet.xyz

# ── ZK Artifacts ──────────────────────────────────────────────────────────────
# Base URL for ZK proving artifacts (signet_email.wasm + signet_email.zkey).
# Defaults to /artifacts (served locally). For production / Vercel, point to the
# GitHub Release that hosts the .zkey (299 MB — too large for the repo).
# NEXT_PUBLIC_ARTIFACT_BASE_URL=https://github.com/turnstile-labs/signet-pass/releases/download/artifacts-v1

# ── Contracts ─────────────────────────────────────────────────────────────────
# Address of the deployed Signet pass factory on Base Sepolia.
# Defaults to the Signet-maintained factory: 0x19F2d083BF21Bb7eB95893aDc28D0D9Cb61F22Bf
# NEXT_PUBLIC_FACTORY_ADDRESS=0x19F2d083BF21Bb7eB95893aDc28D0D9Cb61F22Bf

# ── RPC / Infra ───────────────────────────────────────────────────────────────
# Alchemy API key — used for Base Sepolia RPC AND as the paymaster service URL
# so Coinbase Smart Wallet users can transact without gas.
# Without this key, transactions fall back to standard gas-required EOA flow.
# Get your key at: https://dashboard.alchemy.com/apps
# (Also enable "Gas Manager" on the app and add a policy for Base Sepolia)
NEXT_PUBLIC_ALCHEMY_API_KEY=

# WalletConnect project ID — required for WalletConnect connector in ConnectKit.
# Get your ID at: https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# ── Development only ──────────────────────────────────────────────────────────
# Set to "true" to skip ZK proof generation (uses a dummy attestation instead).
# NEVER enable this in production — it completely bypasses the sybil-resistance guarantee.
NEXT_PUBLIC_DEV_BYPASS=false
