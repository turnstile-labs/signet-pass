# Copy to .env and fill in your values

# Private key of the deploying wallet (get testnet ETH from https://www.alchemy.com/faucets/base-sepolia)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Unix timestamp emails must predate — default is 2024-01-01 00:00:00 UTC
SNAPSHOT_CUTOFF=1704067200

# (Optional) Initial DKIM pubkey hash to register on deploy.
# Run:  node circuits/scripts/prove.mjs test-good.eml
# Copy pubSignals[0] here.
DKIM_PUBKEY_HASH=0

# BaseScan API key — free at https://basescan.org/myapikey (needed for --verify)
BASESCAN_API_KEY=your_basescan_api_key_here

# ── Frontend (filled in after deployment) ──────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_ATTESTATION_CACHE=
NEXT_PUBLIC_DKIM_REGISTRY=
NEXT_PUBLIC_VERIFIER=
